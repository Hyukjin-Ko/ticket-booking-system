# 이 파일은 커밋된다 (예시 템플릿). 실제 값은 .env 에만 둔다 (.gitignore).
# 로컬 셋업: `cp .env.example .env` 후 JWT_SECRET 생성: `openssl rand -base64 48`

# JWT 서명 비밀 키 (HS256, 32바이트 이상 필수, 64자 권장)
JWT_SECRET=replace-me-with-openssl-rand-base64-48-output

# Postgres
DB_URL=jdbc:postgresql://localhost:5432/ticket
DB_USERNAME=ticket
DB_PASSWORD=ticket

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
